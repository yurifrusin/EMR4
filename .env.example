# Environment: dev | staging | production
# In any non-dev environment the app REFUSES TO START unless SECRET_KEY is changed
# from its public default (the repo is open-source, so a default key = forgeable tokens).
ENVIRONMENT=dev

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/gp_pms_dev

# JWT Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS allow-list (JSON array). Defaults cover GitHub Pages + the webpack dev-server.
# CORS_ORIGINS=["https://yurifrusin.github.io","http://localhost:3000"]

# Google Cloud
GCP_PROJECT=emr4-copilot
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=gcp-key.json

# Vertex AI Search (MBS)
DATA_STORE_ID=mbs-search-app_1780903132373
DATA_STORE_LOCATION=global

# ClickSend SMS
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=

# Patient file storage (dev: point at your OneDrive-synced folder so Word Online can open files)
# Example: PATIENT_FILES_DIR=C:\Users\YuriFrusin\OneDrive\EMR4_Patients
PATIENT_FILES_DIR=./patient_files
